# Ozone Prediction API - Environment Configuration
# Copy this file to .env and fill in your actual values

# Google AI Studio Configuration
# Get your free API key from: https://ai.google.dev/tutorials/python_quickstart
GOOGLE_API_KEY=your_google_api_key_here

# API Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Model Paths (relative to app location)
ML_MODELS_PATH=./models/
DL_MODELS_PATH=./models/
SCALER_PATH=./models/scaler.pkl
